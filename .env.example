# Frontend env. Copy to .env (gitignored) for local dev.
# In production, set this on your hosting platform (Vercel/Netlify/etc.)
# rather than committing the file.
VITE_API_BASE=https://darkslategrey-snail-415133.hostingersite.com

# Firebase web SDK config (safe to commit — these identify the project, not secrets).
# Get values from Firebase Console → Project settings → Your apps → Web app.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# OneSignal app ID (public — ships in the browser SDK init). Override this in
# any non-production build so devs/staging don't push to the prod app.
VITE_ONESIGNAL_APP_ID=
